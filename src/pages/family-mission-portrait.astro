---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CallToAction from '../components/CallToAction.astro';
---

<BaseLayout title="Marriage & Family Mission Portrait™" description="Discover your shared purpose as a couple or family through a personalized Mission Portrait™ — a visual legacy your marriage or family can live by every day.">

  <!-- ===== HERO ===== -->
  <PageHero
    variant="dark"
    image="/images/family-mp-lammers.jpeg"
    imageAlt="Example of a Family Mission Portrait"
    title='Marriage & Family<br/><em>Mission Portrait™</em>'
    subtitle="A personalized visual legacy that captures your shared purpose, values, and vision — for married couples and families at every stage of life."
  />

  <!-- ===== WHAT IS IT ===== -->
  <section class="relative py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        <div>
          <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">The Experience</p>
          <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1] mb-6">
            What is a Marriage & Family<br/><em>Mission Portrait™?</em>
          </h2>
          <div class="reveal reveal-d2 space-y-4 text-stone text-base leading-relaxed">
            <p>
              A Family Mission Portrait™ is a guided experience where your family or marriage comes together to discover your shared purpose — who you are together, what you value, and the mission only your family can carry out.
            </p>
            <p>
              Through a facilitated 2-hour workshop, your family or couple identifies your core values, defines your shared vision, and crafts a mission statement — all captured in a personalized, visual Mission Portrait™ that becomes a daily reminder of your shared purpose.
            </p>
            <p>
              It's more than an exercise — it's a legacy. Families and couples hang their Mission Portrait in their home as a compass that guides decisions, strengthens unity, and keeps everyone anchored to what matters most. When a family shares a purpose, everything changes.
            </p>
          </div>
        </div>
        <div class="reveal reveal-d1">
          <img src="/images/mission-portrait-diagram.png" alt="Mission Portrait™ framework — Core Values, Vision, Mission, and ID" class="w-full rounded-2xl" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VIDEO TESTIMONIAL ===== -->
  <section class="relative py-24 md:py-32 bg-warm-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-12 md:mb-16">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">From a Family Who Did It</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1]">
          Hear what it meant <em>to their family.</em>
        </h2>
      </div>

      <div class="reveal max-w-3xl mx-auto">
        <div class="rounded-2xl overflow-hidden border border-sand/50 shadow-lg">
          <video
            controls
            preload="metadata"
            class="w-full aspect-video bg-charcoal"
            poster="/images/family-mp-pitts.jpeg"
          >
            <source src="/videos/family-testimonial.mp4" type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        </div>
        <p class="text-stone text-sm text-center mt-4">The Pitts Family — Belize</p>
      </div>
    </div>
  </section>

  <!-- ===== REAL FAMILY EXAMPLES ===== -->
  <section class="relative py-24 md:py-32 bg-charcoal overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-ember/5 to-transparent pointer-events-none"></div>

    <div class="relative max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">Real Families. Real Portraits.</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-white leading-[1.1]">
          Every portrait is <em class="text-ember">uniquely yours.</em>
        </h2>
        <p class="reveal reveal-d2 text-white/60 text-base md:text-lg mt-6 max-w-2xl mx-auto leading-relaxed">
          No two marriages or families are the same — and neither are their Mission Portraits. Each one reflects the shared purpose, values, and vision that make you who you are together. Click any portrait to view it full size.
        </p>
      </div>

      <div class="grid sm:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          { src: "/images/family-mp-lammers.jpeg", alt: "The Lammers Marriage Mission Portrait" },
          { src: "/images/family-mp-pitts.jpeg", alt: "The Pitts Family Mission Portrait" },
          { src: "/images/family-mp-hopson.jpeg", alt: "The Hopson Marriage Mission Portrait" },
        ].map((portrait, i) => (
          <button type="button" class:list={["reveal rounded-xl overflow-hidden border border-white/10 hover:border-ember/30 transition-all duration-300 cursor-pointer group portrait-trigger", `reveal-d${i + 1}`]} data-lightbox-src={portrait.src}>
            <img src={portrait.src} alt={portrait.alt} class="w-full h-auto group-hover:scale-105 transition-transform duration-500" />
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox overlay -->
  <div id="portrait-lightbox" class="fixed inset-0 z-[100] items-center justify-center bg-charcoal/90 backdrop-blur-sm cursor-pointer" style="display:none;">
    <button type="button" id="lightbox-close" class="absolute top-6 right-6 z-10 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors duration-300 cursor-pointer" aria-label="Close">
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="Mission Portrait™" class="max-w-[90vw] max-h-[90vh] object-contain rounded-2xl shadow-2xl" />
  </div>

  <!-- ===== WHAT YOU LEAVE WITH ===== -->
  <section class="relative py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">What You Leave With</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1]">
          More than a workshop. <em>A legacy.</em>
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            number: "01",
            heading: "Shared Core Values",
            desc: "Your family or marriage identifies the values that define who you are together — the foundation everything else is built on.",
          },
          {
            number: "02",
            heading: "A Clear Vision",
            desc: "A shared picture of the impact you want to make together — your 'why' that gives direction and purpose.",
          },
          {
            number: "03",
            heading: "A Shared Mission",
            desc: "A statement that captures how you live out your values and vision together — your daily compass.",
          },
          {
            number: "04",
            heading: "Your Mission Portrait™",
            desc: "A personalized, visual portrait you can frame and hang in your home — a daily reminder of who you are and what you stand for.",
          },
        ].map((item, i) => (
          <div class:list={["reveal bg-warm-white rounded-xl border border-sand/50 p-8", `reveal-d${i + 1}`]}>
            <p class="font-display text-4xl text-ember/80 mb-4">{item.number}</p>
            <h3 class="text-lg font-medium text-charcoal mb-3">{item.heading}</h3>
            <p class="text-stone text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THREE WAYS TO EXPERIENCE IT ===== -->
  <section class="relative py-24 md:py-32 bg-warm-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">How to Get Started</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1]">
          Three ways to <em>experience it.</em>
        </h2>
        <p class="reveal reveal-d2 text-stone text-base md:text-lg mt-6 max-w-2xl mx-auto leading-relaxed">
          Whether you're a couple doing it on your own, a group gathering for a workshop, or an organization looking to scale — there's a path for you.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- Option 1: On Your Own -->
        <div class="reveal bg-white rounded-2xl border border-sand/50 p-8 md:p-10 flex flex-col">
          <div class="w-12 h-12 rounded-xl bg-ember/10 flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-3">For Couples & Families</p>
          <h3 class="font-display text-xl text-charcoal mb-3">On Your Own</h3>
          <p class="text-stone text-sm leading-relaxed mb-6 flex-1">
            Complete the Mission Portrait as a couple or family at your own pace with our self-guided workbook ($35), or book a facilitated 1-on-1 session with a Certified Facilitator who walks you through it together ($299).
          </p>
          <a href="/mission-portrait#pricing" class="group inline-flex items-center gap-2 text-sm font-medium text-ember hover:text-charcoal transition-colors duration-300">
            View options & pricing
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Option 2: Attend a Workshop -->
        <div class="reveal reveal-d1 bg-white rounded-2xl border border-sand/50 p-8 md:p-10 flex flex-col">
          <div class="w-12 h-12 rounded-xl bg-ember/10 flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-3">For Groups</p>
          <h3 class="font-display text-xl text-charcoal mb-3">Attend a Workshop</h3>
          <p class="text-stone text-sm leading-relaxed mb-6 flex-1">
            Join a 2-hour facilitated group workshop hosted by a church, nonprofit, or community organization. Multiple couples and families participate together — guided through the Mission Portrait process in a shared, meaningful experience. Everyone leaves with their own personalized portrait.
          </p>
          <a href="/contact?interest=marriage-family-workshop" class="group inline-flex items-center gap-2 text-sm font-medium text-ember hover:text-charcoal transition-colors duration-300">
            Find or host a workshop
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Option 3: Scale Across Your Organization -->
        <div class="reveal reveal-d2 bg-white rounded-2xl border-2 border-ember/30 p-8 md:p-10 flex flex-col relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-ember text-white text-[11px] uppercase tracking-[0.2em] font-medium px-4 py-1.5 rounded-bl-xl">For Organizations</div>
          <div class="w-12 h-12 rounded-xl bg-ember/10 flex items-center justify-center mb-6">
            <svg class="w-5 h-5 text-ember" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-3">For Churches, Nonprofits & Ministries</p>
          <h3 class="font-display text-xl text-charcoal mb-3">Scale Across Your Organization</h3>
          <p class="text-stone text-sm leading-relaxed mb-6 flex-1">
            Certify your own leaders to facilitate the Marriage & Family Mission Portrait across your entire community — small groups, couples ministry, regions, or even internationally. A 3-step process built for multiplication.
          </p>
          <a href="#scale" class="group inline-flex items-center gap-2 text-sm font-medium text-ember hover:text-charcoal transition-colors duration-300">
            See the 3-step process below
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== BRING IT TO YOUR ORGANIZATION ===== -->
  <section id="scale" class="relative py-24 md:py-32 bg-charcoal overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-ember/5 to-transparent pointer-events-none"></div>

    <div class="relative max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">Scale Across Your Organization</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-white leading-[1.1]">
          Bring the Marriage & Family Mission Portrait™<br/><em class="text-ember">to your community.</em>
        </h2>
        <p class="reveal reveal-d2 text-white/60 text-base md:text-lg mt-6 max-w-3xl mx-auto leading-relaxed">
          Whether you're a church, nonprofit, ministry, or community organization — locally or internationally — the Marriage & Family Mission Portrait is built to scale through your existing leadership structure.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          {
            num: "01",
            title: "Mission Portrait Workshop for Leaders",
            desc: "Your leadership team goes through the Mission Portrait firsthand — via live workshop or Zoom. You can't lead what you haven't lived. This creates the clarity, ownership, and conviction to champion it across your organization.",
          },
          {
            num: "02",
            title: "Certify Your Facilitators",
            desc: "We train and certify the leaders you choose to equip — showing them how to facilitate the Mission Portrait with excellence, guide meaningful discussion, and lead couples and families through the process with confidence.",
          },
          {
            num: "03",
            title: "License & Launch",
            desc: "An annual license or pilot MOU gives your organization access to all curriculum, workbooks, videos, and ongoing support. Your certified leaders begin facilitating across small groups, ministries, or regions — scaling as far as your network reaches.",
          },
        ].map((step, i) => (
          <div class:list={["reveal bg-white/5 backdrop-blur-sm rounded-xl border border-white/10 p-8 md:p-10", `reveal-d${i + 1}`]}>
            <span class="font-display text-5xl text-ember/40">{step.num}</span>
            <h3 class="mt-4 font-display text-xl md:text-2xl text-white leading-[1.2] mb-3">{step.title}</h3>
            <p class="text-sm text-white/60 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>

      <!-- International Note -->
      <div class="reveal mt-12 max-w-3xl mx-auto rounded-xl bg-white/5 border border-white/10 p-8 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-3">International Organizations Welcome</p>
        <p class="text-white/60 text-sm leading-relaxed">
          We partner with organizations around the world. All curriculum, workbooks, and videos can be translated into your language, and our automation tools can be adapted to support your context — making the Mission Portrait experience natural and accessible for every couple and family you serve.
        </p>
      </div>

      <div class="reveal mt-10 text-center">
        <a
          href="/contact?interest=marriage-family-portrait-organization"
          class="group inline-flex items-center gap-3 px-8 py-4 rounded-full text-sm font-medium tracking-wide text-white bg-ember hover:bg-ember-light hover:shadow-xl hover:shadow-ember/15 transition-all duration-400 hover:scale-[1.02]"
        >
          Partner With Us
          <svg class="w-4 h-4 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="relative py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-14">
          <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-4">Common Questions</p>
          <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1]">
            Frequently <em>asked.</em>
          </h2>
        </div>

        <div class="space-y-0">
          {[
            {
              q: "Who is this for?",
              a: "Any married couple or family — whether you're newlyweds discovering your shared purpose, parents with young kids, a family with teenagers, or empty nesters looking to reconnect. It's designed for every stage of marriage and family life.",
            },
            {
              q: "Can this be done as a couple without kids?",
              a: "Absolutely. A Marriage Mission Portrait™ is one of the most powerful things you can do for your relationship — defining your shared purpose, values, and vision together. Many couples do this as a standalone experience, and it's the foundation of what organizations use when scaling across their couples ministry.",
            },
            {
              q: "How long does the workshop take?",
              a: "The workshop is a 2-hour facilitated experience. Everything you need is provided — just bring your family or come as a couple.",
            },
            {
              q: "What do we leave with?",
              a: "Every family or couple leaves with a personalized, custom-designed Mission Portrait™ — a visual portrait that captures your core values, vision, and mission. It's designed to be framed and displayed in your home as a daily reminder.",
            },
            {
              q: "How do we sign up?",
              a: "If your church, nonprofit, or community organization is hosting a workshop, they'll provide a registration link. If you'd like to bring a Family Mission Portrait™ workshop to your organization or community — whether locally or internationally — contact us to get started.",
            },
          ].map((faq, i) => (
            <details class:list={["reveal group border-b border-sand/60 last:border-b-0", i > 0 && `reveal-d${Math.min(i, 4)}`]}>
              <summary class="flex items-center justify-between gap-4 py-6 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                <h3 class="font-display text-lg md:text-xl text-charcoal group-hover:text-ember transition-colors duration-300">{faq.q}</h3>
                <svg class="w-5 h-5 text-stone flex-shrink-0 transition-transform duration-300 group-open:rotate-45" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
              </summary>
              <p class="pb-6 text-sm text-stone leading-relaxed -mt-1">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <CallToAction
    title='Create your shared<br/><em class="ember-gradient">legacy.</em>'
    image="/images/family-mp-hopson.jpeg"
    buttonText="Get Started"
    buttonHref="/contact?interest=family-mission-portrait"
  />

</BaseLayout>

<script>
  const lightbox = document.getElementById('portrait-lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');

  function openLightbox(src: string) {
    if (lightbox && lightboxImg) {
      lightboxImg.src = src;
      lightbox.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
  }

  function closeLightbox() {
    if (lightbox) {
      lightbox.style.display = 'none';
      document.body.style.overflow = '';
    }
  }

  document.querySelectorAll('.portrait-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const src = (trigger as HTMLElement).dataset.lightboxSrc;
      if (src) openLightbox(src);
    });
  });

  lightboxClose?.addEventListener('click', (e) => {
    e.stopPropagation();
    closeLightbox();
  });

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
