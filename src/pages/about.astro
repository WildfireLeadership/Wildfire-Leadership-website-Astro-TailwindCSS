---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SplitSection from '../components/SplitSection.astro';
import CallToAction from '../components/CallToAction.astro';
---

<BaseLayout title="Our Story" description="Learn about Wildfire Leadership's mission to help individuals and organizations discover their purpose and unleash their potential.">

  <!-- ===== HERO — Dark hero with real image ===== -->
  <PageHero
    variant="dark"
    image="/images/hero-main.jpg"
    imageAlt="Wildfire Leadership team"
    title='Our <em>Story</em>'
    subtitle="Wildfire Leadership exists to help ignite your journey — equipping you with practical, visual, and straightforward tools proven to unleash your potential."
  />

  <!-- ===== VIDEO SECTION — White bg ===== -->
  <section class="relative py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">Our Story</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1]">
          See what <em>drives us.</em>
        </h2>
        <p class="reveal reveal-d2 mt-6 text-base md:text-lg text-stone leading-relaxed">
          Check out the video below to learn more about the Wildfire story!
        </p>
      </div>

      <!-- Video Embed -->
      <div class="reveal reveal-d3 mt-14 max-w-4xl mx-auto">
        <div class="relative aspect-video rounded-2xl overflow-hidden">
          <iframe
            src="https://player.vimeo.com/video/1161633019?title=0&byline=0&portrait=0&badge=0&vimeo_logo=0&dnt=1"
            title="The Wildfire Story"
            class="absolute inset-0 w-full h-full"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SPLIT — Mission description ===== -->
  <SplitSection
    label="Our Mission"
    title='Ignite your journey to<br/><em>discover purpose.</em>'
    description="We know what it's like to search for direction — in your career, your family, your organization. Wildfire Leadership exists to help you find it. With over 40,000 Mission Portraits completed across education, business, churches, and families, we equip people with practical, visual tools that make purpose clear and actionable."
    image="/images/hero-cta.jpg"
    imageAlt="Wildfire Leadership mission"
    imagePosition="right"
    bg="warm-white"
    link={{ text: "Meet our team", href: "/team" }}
  />

  <!-- ===== THE TRANSFORMATION ===== -->
  <section class="relative py-24 md:py-32 bg-cream">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-4">The Transformation</p>
        <h2 class="reveal reveal-d1 font-display text-4xl md:text-5xl text-charcoal leading-[1.05]">
          Before & <em>after.</em>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
        <!-- Before -->
        <div class="reveal p-8 md:p-10 rounded-xl bg-white border border-sand/50">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-charcoal/40 mb-6">Before Wildfire</p>
          <ul class="space-y-4 text-stone">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-charcoal/20 shrink-0"></span>
              <span class="text-sm leading-relaxed">"I know I'm meant for more, but I can't articulate it."</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-charcoal/20 shrink-0"></span>
              <span class="text-sm leading-relaxed">"Our team is talented but not aligned around a shared mission."</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-charcoal/20 shrink-0"></span>
              <span class="text-sm leading-relaxed">"My students are capable, but they lack direction and confidence."</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-charcoal/20 shrink-0"></span>
              <span class="text-sm leading-relaxed">"Our family is busy but disconnected from a shared purpose."</span>
            </li>
          </ul>
        </div>

        <!-- After -->
        <div class="reveal reveal-d1 p-8 md:p-10 rounded-xl bg-charcoal text-white">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">After Wildfire</p>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-ember shrink-0"></span>
              <span class="text-sm leading-relaxed text-white/80">"I can see my purpose clearly — and I have a roadmap to live it out."</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-ember shrink-0"></span>
              <span class="text-sm leading-relaxed text-white/80">"Our team is unified, energized, and moving in the same direction."</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-ember shrink-0"></span>
              <span class="text-sm leading-relaxed text-white/80">"My students are engaged, confident, and thinking about their future."</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-ember shrink-0"></span>
              <span class="text-sm leading-relaxed text-white/80">"Our family has a shared vision and we're building toward it together."</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA CLOSER ===== -->
  <CallToAction
    title='Discover your <em class="ember-gradient">purpose.</em>'
    description="Take the first step toward uncovering your mission and unleashing your full potential."
    buttonText="Explore Our Tools"
    buttonHref="/mission-portrait"
  />

</BaseLayout>
