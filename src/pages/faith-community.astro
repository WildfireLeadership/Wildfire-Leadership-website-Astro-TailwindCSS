---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import CallToAction from '../components/CallToAction.astro';
---

<BaseLayout title="Faith & Community" description="Purpose-driven, faith-based tools and curriculum for churches, non-profits, and community organizations — from leadership workshops to organization-wide implementation.">

  <!-- ===== HERO ===== -->
  <PageHero
    variant="dark"
    image="/images/hero-main.jpg"
    title='Faith &<br/><em>Community</em>'
    subtitle="Purpose-driven, faith-based tools and curriculum for churches, non-profits, and community organizations."
  />

  <!-- ===== PARTNERS ===== -->
  <section class="relative py-16 md:py-20 bg-charcoal-deep border-t border-white/5">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <p class="reveal text-[11px] uppercase tracking-[0.3em] text-white/40 text-center mb-10">Some of the organizations we partner with</p>
      <div class="reveal reveal-d1 flex flex-wrap justify-center items-center gap-6 md:gap-8">
        {[
          { src: "/images/church-logo-seacoast.webp", alt: "Seacoast Church" },
          { src: "/images/church-logo-seu.webp", alt: "Southeastern University", dark: true },
          { src: "/images/church-logo-xperience.webp", alt: "Xperience Church", dark: true },
          { src: "/images/church-logo-newlife.webp", alt: "New Life Church" },
          { src: "/images/church-logo-jicc.png", alt: "James Island Christian Church" },
          { src: "/images/church-logo-freedom.png", alt: "Freedom Church" },
          { src: "/images/church-logo-glccg.png", alt: "Great Lakes Conference Churches of God" },
          { src: "/images/church-logo-faith.png", alt: "Faith Church", dark: true },
          { src: "/images/church-logo-churchcreek.jpeg", alt: "The Retreat at Church Creek" },
        ].map((logo) => (
          <div class:list={["rounded-xl p-4 flex items-center justify-center h-20 w-28 md:h-22 md:w-32 hover:shadow-lg transition-all duration-300", logo.dark ? "bg-charcoal hover:shadow-white/10" : "bg-white hover:shadow-white/10"]}>
            <img src={logo.src} alt={logo.alt} class="max-h-12 md:max-h-14 w-auto object-contain" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INTRO ===== -->
  <section class="relative py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">Welcome</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1] mb-8">
          Equipping Communities to<br/><em>Lead with Purpose</em>
        </h2>
        <p class="reveal reveal-d2 text-lg md:text-xl text-stone leading-relaxed">
          We partner with churches, non-profits, and community organizations to help leaders, families, and teams discover their God-given purpose. All of our curriculum is faith-based and available digitally — designed to integrate into the life of your organization.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIAL ===== -->
  <section class="relative py-24 md:py-32 bg-warm-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <TestimonialCard
        variant="large"
        quote="I had the opportunity to go through the Mission Portrait — one of Wildfire's core tools — and it brought fresh clarity to my purpose and vision. Now I'm seeing that same impact across students, families, and marriages. I haven't seen anything quite like it."
        name="Greg Surratt"
        title="Co-Founder, ARC"
      />
    </div>
  </section>

  <!-- ===== OUR TOOLS ===== -->
  <section class="relative py-24 md:py-32 bg-warm-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-12 md:mb-16">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">Our Tools</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1]">
          Two Tools. <em>One Transformation.</em>
        </h2>
        <p class="reveal reveal-d2 text-stone text-base md:text-lg mt-6 max-w-2xl mx-auto leading-relaxed">
          Every engagement is built on two proprietary, faith-based frameworks designed to help your people uncover purpose and unleash potential.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <a href="/mission-portrait" class="reveal group bg-white rounded-2xl border border-sand/50 overflow-hidden hover:border-ember/30 transition-colors duration-300">
          <img src="/images/mission-portrait-diagram.png" alt="Mission Portrait™ framework diagram" class="w-full" />
          <div class="p-6 md:p-8">
            <h3 class="font-display text-xl text-charcoal leading-[1.1] mb-2">Mission Portrait™</h3>
            <p class="text-stone text-sm leading-relaxed mb-3">
              A personalized visual guide that helps individuals, couples, and families articulate their God-given purpose, values, and vision.
            </p>
            <p class="text-ember text-sm font-medium group-hover:underline">Learn more &rarr;</p>
          </div>
        </a>
        <a href="/7-igniters" class="reveal reveal-d1 group bg-white rounded-2xl border border-sand/50 overflow-hidden hover:border-ember/30 transition-colors duration-300">
          <img src="/images/7-igniters-diagram.png" alt="The 7 Igniters™ framework" class="w-full" />
          <div class="p-6 md:p-8">
            <h3 class="font-display text-xl text-charcoal leading-[1.1] mb-2">The 7 Igniters™</h3>
            <p class="text-stone text-sm leading-relaxed mb-3">
              A customized discipleship and leadership curriculum that guides your people through seven stages of purpose-driven growth.
            </p>
            <p class="text-ember text-sm font-medium group-hover:underline">Learn more &rarr;</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== WAYS WE SERVE YOUR CHURCH ===== -->
  <section id="workshops" class="relative py-24 md:py-32 bg-white">
    <div class="max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-6 md:mb-8">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">Ways We Serve Your Organization</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-charcoal leading-[1.1]">
          Start Where <em>You Need It Most</em>
        </h2>
      </div>
      <p class="reveal reveal-d2 text-stone text-base md:text-lg text-center max-w-2xl mx-auto leading-relaxed mb-16">
        Each offering stands on its own — pick one, combine a few, or build toward a full rollout. There's no required order.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Students & Young Adults -->
        <div class="reveal bg-warm-white rounded-xl border border-sand/50 p-8 md:p-10">
          <p class="text-[12px] uppercase tracking-[0.15em] text-ember mb-3">Students & Young Adults</p>
          <h3 class="text-xl font-medium text-charcoal mb-4">Purpose, Identity & Leadership Curriculum</h3>
          <p class="text-stone text-sm leading-relaxed mb-5">
            Help your students and young adults discover who they are, where they're headed, and how to lead from that place. Our Mission Portrait™ and 7 Igniters™ curriculum is designed for small groups, classes, and youth ministry — building personal leadership, clarity, and confidence in the next generation.
          </p>
          <a href="/contact?interest=faith" class="group inline-flex items-center gap-2 text-sm font-medium text-charcoal/60 hover:text-ember transition-colors duration-400">
            Request info
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Marriage -->
        <div class="reveal bg-warm-white rounded-xl border border-sand/50 p-8 md:p-10">
          <p class="text-[12px] uppercase tracking-[0.15em] text-ember mb-3">Marriage</p>
          <h3 class="text-xl font-medium text-charcoal mb-4">INVEST Marriage</h3>
          <p class="text-stone text-sm leading-relaxed mb-5">
            Strengthen marriages across your community through our INVEST Marriage curriculum — an 8-week small group series — plus Couples Mission Portrait™ workshops and marriage coaching.
          </p>
          <a href="/invest-marriage" class="group inline-flex items-center gap-2 text-sm font-medium text-charcoal/60 hover:text-ember transition-colors duration-400">
            Learn more about INVEST
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Marriage & Family -->
        <div class="reveal bg-warm-white rounded-xl border border-sand/50 p-8 md:p-10">
          <p class="text-[12px] uppercase tracking-[0.15em] text-ember mb-3">Marriage & Family</p>
          <h3 class="text-xl font-medium text-charcoal mb-4">Marriage & Family Mission Portrait™</h3>
          <p class="text-stone text-sm leading-relaxed mb-5">
            Help married couples and families discover their shared purpose, values, and vision. Each couple or family leaves with a personalized Mission Portrait™ — a visual legacy they can live by every day.
          </p>
          <a href="/family-mission-portrait" class="group inline-flex items-center gap-2 text-sm font-medium text-charcoal/60 hover:text-ember transition-colors duration-400">
            See examples & learn more
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Congregation Engagement -->
        <div class="reveal bg-warm-white rounded-xl border border-sand/50 p-8 md:p-10">
          <p class="text-[12px] uppercase tracking-[0.15em] text-ember mb-3">Congregation Engagement</p>
          <h3 class="text-xl font-medium text-charcoal mb-4">Flip the Script + Echo</h3>
          <p class="text-stone text-sm leading-relaxed mb-5">
            Grow discipleship and keep your congregation engaged all week. The Flip the Script app's Echo feature takes your pastor's Sunday message and creates a 6-day devotional from it — extending the sermon's impact into daily life.
          </p>
          <a href="https://getflipthescript.com/" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 text-sm font-medium text-charcoal/60 hover:text-ember transition-colors duration-400">
            Learn more
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Leadership Development -->
        <div class="reveal bg-warm-white rounded-xl border border-sand/50 p-8 md:p-10">
          <p class="text-[12px] uppercase tracking-[0.15em] text-ember mb-3">Leadership Development</p>
          <h3 class="text-xl font-medium text-charcoal mb-4">Workshops & Coaching</h3>
          <p class="text-stone text-sm leading-relaxed mb-5">
            Equip your leadership team with proven tools and frameworks — Working Genius, Mission Portrait™, 5 Levels of Leadership, DISC, Crucial Conversations, and more. Includes ongoing team coaching tailored for your church, nonprofit, or organization.
          </p>
          <a href="/contact?interest=faith" class="group inline-flex items-center gap-2 text-sm font-medium text-charcoal/60 hover:text-ember transition-colors duration-400">
            Request info
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Keynote Speaking -->
        <div class="reveal bg-warm-white rounded-xl border border-sand/50 p-8 md:p-10">
          <p class="text-[12px] uppercase tracking-[0.15em] text-ember mb-3">Speaking</p>
          <h3 class="text-xl font-medium text-charcoal mb-4">Keynote Speaking</h3>
          <p class="text-stone text-sm leading-relaxed mb-5">
            Bill and Stephanie Lammers are available for keynotes at conferences, retreats, and special events — sharing the frameworks, tools, and stories behind Wildfire Leadership and INVEST Marriage.
          </p>
          <a href="/contact?interest=faith" class="group inline-flex items-center gap-2 text-sm font-medium text-charcoal/60 hover:text-ember transition-colors duration-400">
            Request speaking info
            <svg class="w-3.5 h-3.5 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

      </div>

      <div class="reveal mt-12 text-center">
        <a href="/contact?interest=faith" class="group inline-flex items-center gap-3 px-8 py-4 rounded-full text-sm font-medium tracking-wide text-white bg-charcoal hover:bg-ember transition-all duration-400 hover:shadow-lg hover:shadow-ember/20">
          Contact us for pricing
          <svg class="w-4 h-4 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== READY TO GO DEEPER? ===== -->
  <section class="relative py-24 md:py-32 bg-charcoal overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-ember/5 to-transparent pointer-events-none"></div>

    <div class="relative max-w-[1400px] mx-auto px-5 md:px-8">
      <div class="text-center mb-16 md:mb-20">
        <p class="reveal text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-6">For Organizations Ready to Scale</p>
        <h2 class="reveal reveal-d1 font-display text-3xl md:text-4xl lg:text-5xl text-white leading-[1.1]">
          Ready to roll this out across<br/><em class="text-ember">your entire organization?</em>
        </h2>
        <p class="reveal reveal-d2 text-white/60 text-base md:text-lg mt-6 max-w-3xl mx-auto leading-relaxed">
          Any of the offerings above can be scaled across your organization through a simple, proven 3-step process. Whether you want to bring the Mission Portrait to every couple, the 7 Igniters to every student, or leadership tools to every team — here's how.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          {
            step: "01",
            title: "Leadership Experience",
            desc: "Your leadership team goes through the Mission Portrait™ and Working Genius firsthand — via workshop or Zoom. You can't lead what you haven't lived. This builds clarity, alignment, and conviction before rolling anything out.",
          },
          {
            step: "02",
            title: "Certify Your Facilitators",
            desc: "We train and certify the leaders you choose — giving them the tools and confidence to facilitate Mission Portrait™, 7 Igniters™, or INVEST Marriage on their own across your community.",
          },
          {
            step: "03",
            title: "License & Launch",
            desc: "An annual license gives your organization access to all curriculum, workbooks, videos, and ongoing support. Your certified leaders begin facilitating across small groups, ministries, teams, or regions — scaling as far as your network reaches.",
          },
        ].map((item, i) => (
          <div class:list={["reveal bg-white/5 backdrop-blur-sm rounded-xl border border-white/10 p-8 md:p-10", `reveal-d${i + 1}`]}>
            <span class="font-display text-5xl text-ember/40">{item.step}</span>
            <h3 class="mt-4 font-display text-xl md:text-2xl text-white leading-[1.2] mb-3">{item.title}</h3>
            <p class="text-sm text-white/60 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <div class="reveal mt-12 max-w-3xl mx-auto rounded-xl bg-white/5 border border-white/10 p-8 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-ember mb-3">International Organizations Welcome</p>
        <p class="text-white/60 text-sm leading-relaxed">
          We partner with organizations around the world. All curriculum and materials can be translated into your language and adapted for your context.
        </p>
      </div>

      <div class="reveal mt-10 text-center">
        <a
          href="/contact?interest=faith"
          class="group inline-flex items-center gap-3 px-8 py-4 rounded-full text-sm font-medium tracking-wide text-white bg-ember hover:bg-ember-light hover:shadow-xl hover:shadow-ember/15 transition-all duration-400 hover:scale-[1.02]"
        >
          Start the Conversation
          <svg class="w-4 h-4 transition-transform duration-400 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <CallToAction title='Ignite your<br/><em class="ember-gradient">community.</em>' buttonText="Schedule a Consultation" buttonHref="/contact?interest=faith" />

</BaseLayout>

<style>
  .ember-gradient {
    background: linear-gradient(135deg, #f04a18 0%, #E03500 40%, #d4a04a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

